{
  "version": 1,
  "final_space": true,
  "palette": {
    "red": "#E3655B",
    "blue": "#2274A5",
    "gray": "#2B303A",
		"lightgray": "#D9D9D9"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
    		{
      		"type": "text",
					"foreground": "p:lightgray",
	  			"template": "⣿⡟⠙⠛⠋⠩⠭⣉⡛⢛⠫⠭⠄⠒⠄⠄⠄⠈⠉⠛⢿⣿⣿⣿⣿⣿⣿⣿⣿⣿"
				},
				{
					"type": "text",
					"foreground": "p:lightgray",
	  			"template": "\n⣿⡇⠄⠄⠄⠄⣠⠖⠋⣀⡤⠄⠒⠄⠄⠄⠄⠄⠄⠄⠄⣈⡭⠭⠄⠄⠄⠉⠙"
				},
				{
      		"type": "os",
					"foreground": "p:lightgray",
	  			"template": "\n⣿⡇⠄⠄⢀⣞⣡⠴⠚⠁⠄⠄⢀⠠⠄⠄⠄⠄⠄⠄⠄⠉⠄⠄⠄⠄⠄⠄⠄         \uE62A  Windows"
				},
				{
      		"type": "text",
					"foreground": "p:lightgray",
      		"template": "\n⣿⡇⠄⡴⠁⡜⣵⢗⢀⠄⢠⡔⠁⠄⠄⠄⠄⠄⠄⠄⠄⠄⠄⠄⠄⠄⠄⠄⠄"
				},
				{
      		"type": "sysinfo",
					"foreground": "p:lightgray",
      		"template": "\n⣿⡇⡜⠄⡜⠄⠄⠄⠉⣠⠋⠠⠄⢀⡄⠄⠄⣠⣆⠄⠄⠄⠄⠄⠄⠄⠄⠄⢸         RAM: {{ .PhysicalPercentUsed }}% "
				},
				{
      		"type": "text",
					"foreground": "p:lightgray",
      		"template": "\n⣿⠸⠄⡼⠄⠄⠄⠄⢰⠁⠄⠄⠄⠈⣀⣠⣬⣭⣛⠄⠁⠄⡄⠄⠄⠄⠄⠄⢀⣿"
				},
				{
      		"type": "time",
					"style": "plain",
					"foreground": "p:lightgray",
      		"template": "\n⣏⠄⢀⠁⠄⠄⠄⠄⠇⢀⣠⣴⣶⣿⣿⣿⣿⣿⣿⡇⠄⠄⡇⠄⠄⠄⠄⢀⣾⣿        {{ .CurrentDate.Day }} {{ .CurrentDate.Month }} - {{ .CurrentDate.Weekday }}   "
				},
				{
      		"type": "time",
					"style": "plain",
					"foreground": "p:lightgray",
      		"template": "\n⣿⣸⠈⠄⠄⠰⠾⠴⢾⣻⣿⣿⣿⣿⣿⣿⣿⣿⣿⢁⣾⢀⠁⠄⠄⠄⢠⢸⣿⣿            {{ .CurrentDate.Year }} "
				},
				{
					"foreground": "p:lightgray",
      		"template": "\n⣿⣿⣆⠄⠆⠄⣦⣶⣦⣌⣿⣿⣿⣿⣷⣋⣀⣈⠙⠛⡛⠌⠄⠄⠄⠄⢸⢸⣿⣿"
				},
				{
      		"type": "text",
					"foreground": "p:lightgray",
    			"template": "\n⣿⣿⣿⠄⠄⠄⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⣿⠇⠈⠄⠄⠄⠄⠄⠈⢸⣿⣿"
				},
				{
      		"type": "text",
					"foreground": "p:lightgray",
      		"template": "\n⣿⣿⣿⠄⠄⠄⠘⣿⣿⣿⡆⢀⣈⣉⢉⣿⣿⣯⣄⡄⠄⠄⠄⠄⠄⠄⠄⠈⣿⣿"
				},
				{
      		"type": "text",
					"foreground": "p:lightgray",
      		"template": "\n⣿⣿⡟⡜⠄⠄⠄⠄⠙⠿⣿⣧⣽⣍⣾⣿⠿⠛⠁⠄⠄⠄⠄⠄⠄⠄⠄⠃⢿⣿"
				},
				{ 
      		"type": "text",
					"foreground": "p:lightgray",
      		"template": "\n⣿⡿⠰⠄⠄⠄⠄⠄⠄⠄⠄⠈⠉⠩⠔⠒⠉⠄⠄⠄⠄⠄⠄⠄⠄⠄⠄⠐⠘⣿"
				},
				{
      		"type": "text",
					"foreground": "p:lightgray",
      		"template": "\n⣿⠃⠃⠄⠄⠄⠄⠄⠄⣀⢀⠄⠄⡀⡀⢀⣤⣴⣤⣤⣀⣀⠄⠄⠄⠄⠄⠄⠁⢹\n"
				}
      ]
		},
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
			{
	  		"type": "text",
	  		"style": "diamond",
	  		"template": " Katze ",
				"foreground": "p:lightgray",
	  		"leading_diamond": "\ue0b6",
	  		"trailing_diamond": "\ue0b0",
	  		"background": "p:red"
			},
    	{
      	"type": "text",
      	"style": "diamond",
	  		"trailing_diamond": "\ue0b0",
      	"foreground": "#ffffff",
  	  	"template": " {{ .Folder }}",
	  		"background": "p:blue"
    	},
			{
				"type": "git",
				"style": "powerline",
				"options": {
					"fetch_status": true,
					"fetch_push_status": true,
					"fetch_bare_info": true
				},
				"template": " {{ .HEAD }} {{ .BranchStatus }}  "
			}
    ]
    },
    {
      "type": "rprompt",
      "alignment": "right",
      "segments": [
				{
					"type": "text",
					"style": "diamond",
					"leading_diamond": "\ue0b2",
					"template": "\ue0b3 {{ .PromptCount }} \ue0b1 \ue0b3",
					"background": "p:red"
				},
				{
					"type": "text",
					"style": "diamond",
					"template": "Hello",
					"leading_diamond": "\ue0b2",
					"trailing_diamond": "\ue0b4",
					"background": "p:blue"
				}
      ]
    }
  ]
}
